class Solution {
public:
    vector<int> sumZero(int n) {
        vector<int> v;
            if(n==1){
             v.push_back(0);
             return v;
            }
            for(int i = -(n/2) ; i<=n/2 ; ++i){
                if(n%2 == 0 && i == 0){
                    continue;
                }
                  v.push_back(i);
        }
        return v;
    }
};
